@page "/"
@inject NavigationManager NavigationManager

<PageTitle>Inicio - AdminAI</PageTitle>

<div class="p-8 text-center">
    <h1 class="text-2xl font-bold mb-4">Bienvenido al Asistente Ayuntamiento</h1>
    <p class="text-gray-600 mb-4">Redirigiendo al panel de chat...</p>
