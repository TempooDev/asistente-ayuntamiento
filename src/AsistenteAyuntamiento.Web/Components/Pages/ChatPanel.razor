@page "/chat"
@page "/"
<PageTitle>AdminAI - Panel de Chat</PageTitle>

<div class="flex-1 overflow-y-auto px-margin-mobile md:px-margin-desktop py-xl hide-scrollbar flex flex-col items-center">
    <div class="w-full max-w-[800px] flex flex-col gap-lg">
        <!-- Welcome Message -->
        <div class="flex flex-col items-center justify-center py-xl mt-xl text-center">
            <div class="w-16 h-16 rounded-full bg-surface-container-high flex items-center justify-center mb-md border border-outline-variant shadow-[0_1px_3px_0_rgba(0,0,0,0.1),_0_1px_2px_0_rgba(0,0,0,0.06)]">
                <span class="material-symbols-outlined text-primary text-3xl" style="font-variation-settings: 'FILL' 1;">smart_toy</span>
            </div>
            <h2 class="font-headline-lg text-headline-lg text-on-surface mb-sm">Hola, ¿en qué puedo ayudarte hoy?</h2>
            <p class="font-body-md text-body-md text-on-surface-variant max-w-lg">
                Asistente de IA para administración pública. Consulta normativas, resume resoluciones y analiza documentos institucionales con precisión y seguridad.
            </p>
        </div>
        <!-- Sample Queries -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-md mt-lg w-full">
            <button class="bg-surface-container-lowest border border-outline-variant p-md rounded-xl text-left hover:shadow-[0_4px_6px_-1px_rgba(0,0,0,0.1),_0_2px_4px_-1px_rgba(0,0,0,0.06)] hover:border-primary-container transition-all group flex flex-col gap-sm">
                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">description</span>
                <span class="font-label-md text-label-md text-on-surface">Resumir última resolución del BOE</span>
            </button>
            <button class="bg-surface-container-lowest border border-outline-variant p-md rounded-xl text-left hover:shadow-[0_4px_6px_-1px_rgba(0,0,0,0.1),_0_2px_4px_-1px_rgba(0,0,0,0.06)] hover:border-primary-container transition-all group flex flex-col gap-sm">
                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">manage_search</span>
                <span class="font-label-md text-label-md text-on-surface">Buscar cambios en normativa local</span>
            </button>
            <button class="bg-surface-container-lowest border border-outline-variant p-md rounded-xl text-left hover:shadow-[0_4px_6px_-1px_rgba(0,0,0,0.1),_0_2px_4px_-1px_rgba(0,0,0,0.06)] hover:border-primary-container transition-all group flex flex-col gap-sm">
                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">gavel</span>
                <span class="font-label-md text-label-md text-on-surface">Consultar procedimientos de contratación</span>
            </button>
            <button class="bg-surface-container-lowest border border-outline-variant p-md rounded-xl text-left hover:shadow-[0_4px_6px_-1px_rgba(0,0,0,0.1),_0_2px_4px_-1px_rgba(0,0,0,0.06)] hover:border-primary-container transition-all group flex flex-col gap-sm">
                <span class="material-symbols-outlined text-on-surface-variant group-hover:text-primary transition-colors">analytics</span>
                <span class="font-label-md text-label-md text-on-surface">Analizar impacto presupuestario de BOJA</span>
            </button>
        </div>
    </div>
</div>
<!-- Input Area -->
<div class="w-full bg-surface pb-xl pt-sm px-margin-mobile md:px-margin-desktop flex flex-col items-center">
    <div class="w-full max-w-[800px]">
        <!-- Filters -->
        <div class="flex gap-sm mb-sm overflow-x-auto hide-scrollbar pb-xs">
            <button class="font-label-sm text-label-sm bg-surface-container-low border border-outline-variant text-on-surface px-3 py-1.5 rounded-full hover:bg-surface-container-high transition-colors whitespace-nowrap">BOJA</button>
            <button class="font-label-sm text-label-sm bg-surface-container-low border border-outline-variant text-on-surface px-3 py-1.5 rounded-full hover:bg-surface-container-high transition-colors whitespace-nowrap">BOE</button>
            <button class="font-label-sm text-label-sm bg-surface-container-low border border-outline-variant text-on-surface px-3 py-1.5 rounded-full hover:bg-surface-container-high transition-colors whitespace-nowrap">BOPM</button>
            <button class="font-label-sm text-label-sm bg-surface-container-lowest border border-dashed border-outline text-on-surface-variant px-3 py-1.5 rounded-full hover:bg-surface-container-high transition-colors whitespace-nowrap flex items-center gap-xs">
                <span class="material-symbols-outlined text-[14px]">add</span> Fuentes
            </button>
        </div>
        <!-- Input Box -->
        <div class="relative w-full bg-surface-container-lowest border border-outline-variant rounded-xl shadow-[0_1px_3px_0_rgba(0,0,0,0.1),_0_1px_2px_0_rgba(0,0,0,0.06)] focus-within:border-primary focus-within:ring-2 focus-within:ring-primary-container transition-all">
            <textarea class="w-full bg-transparent border-none rounded-xl p-md pr-16 resize-none focus:ring-0 font-body-md text-body-md text-on-surface placeholder-on-surface-variant min-h-[80px]" placeholder="Escribe tu consulta institucional aquí..." rows="2"></textarea>
            <div class="absolute bottom-md right-md flex gap-sm">
                <button class="p-2 text-on-surface-variant hover:text-primary transition-colors rounded-full hover:bg-surface-container-low">
                    <span class="material-symbols-outlined">attach_file</span>
                </button>
                <button class="p-2 bg-primary text-on-primary rounded-lg hover:opacity-90 transition-opacity flex items-center justify-center">
                    <span class="material-symbols-outlined" style="font-variation-settings: 'FILL' 1;">send</span>
                </button>
            </div>
        </div>
        <div class="text-center mt-xs">
            <span class="font-label-sm text-label-sm text-on-surface-variant opacity-70">La IA puede cometer errores. Verifica la información oficial.</span>
        </div>
    </div>
</div>

