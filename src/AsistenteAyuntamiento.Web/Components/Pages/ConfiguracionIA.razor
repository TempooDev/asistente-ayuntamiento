@page "/configuracion"
<PageTitle>Configuración IA - AdminAI</PageTitle>

<div class="max-w-[800px] mx-auto py-xl">
    <div class="mb-lg">
        <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-background mb-xs">Configuración de IA</h2>
        <p class="font-body-md text-body-md text-on-surface-variant">Gestionar modelos de IA, parámetros de comportamiento e integraciones externas.</p>
    </div>
    <!-- Bento Grid Layout for Settings -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
        <!-- Model Selection Card -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-lg shadow-sm">
            <div class="flex items-center gap-sm mb-md">
                <span class="material-symbols-outlined text-primary" data-icon="model_training">model_training</span>
                <h3 class="font-headline-md text-headline-md text-on-surface">Selección de Modelo</h3>
            </div>
            <p class="font-body-md text-body-md text-on-surface-variant mb-lg text-sm">Selecciona el modelo base para las consultas.</p>
            <div class="space-y-sm">
                <label class="flex items-center justify-between p-md border border-outline-variant rounded-lg cursor-pointer hover:bg-surface-container-low transition-colors bg-surface-container-low border-primary">
                    <div class="flex items-center gap-md">
                        <input checked="" class="text-primary focus:ring-primary w-4 h-4" name="ai-model" type="radio" value="gpt4"/>
                        <div>
                            <span class="block font-label-md text-label-md text-on-surface">GPT-4 Turbo</span>
                            <span class="block text-xs text-on-surface-variant">Alta capacidad de razonamiento</span>
                        </div>
                    </div>
                    <span class="bg-primary-container text-on-primary-container text-[10px] font-bold px-2 py-1 rounded-full uppercase">Activo</span>
                </label>
                <label class="flex items-center justify-between p-md border border-outline-variant rounded-lg cursor-pointer hover:bg-surface-container-low transition-colors">
                    <div class="flex items-center gap-md">
                        <input class="text-primary focus:ring-primary w-4 h-4" name="ai-model" type="radio" value="claude3"/>
                        <div>
                            <span class="block font-label-md text-label-md text-on-surface">Claude 3 Opus</span>
                            <span class="block text-xs text-on-surface-variant">Análisis matizado de documentos</span>
                        </div>
                    </div>
                </label>
                <label class="flex items-center justify-between p-md border border-outline-variant rounded-lg cursor-pointer hover:bg-surface-container-low transition-colors">
                    <div class="flex items-center gap-md">
                        <input class="text-primary focus:ring-primary w-4 h-4" name="ai-model" type="radio" value="llama3"/>
                        <div>
                            <span class="block font-label-md text-label-md text-on-surface">Llama 3 (Interno)</span>
                            <span class="block text-xs text-on-surface-variant">Alojado localmente, seguro</span>
                        </div>
                    </div>
                </label>
            </div>
        </div>
        <!-- Parameters Card -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-lg shadow-sm flex flex-col justify-between">
            <div>
                <div class="flex items-center gap-sm mb-md">
                    <span class="material-symbols-outlined text-primary" data-icon="tune">tune</span>
                    <h3 class="font-headline-md text-headline-md text-on-surface">Parámetros</h3>
                </div>
                <p class="font-body-md text-body-md text-on-surface-variant mb-lg text-sm">Ajusta el estilo de respuesta para el contexto institucional.</p>
                <div class="mb-lg">
                    <div class="flex justify-between items-end mb-xs">
                        <label class="font-label-md text-label-md text-on-surface" for="temperature">Creatividad vs Precisión</label>
                        <span class="text-xs font-bold text-primary bg-primary-container px-2 py-1 rounded-full" id="temp-val">0.3</span>
                    </div>
                    <input class="w-full h-1 bg-surface-variant rounded-lg appearance-none cursor-pointer" id="temperature" max="1" min="0" step="0.1" type="range" value="0.3" oninput="document.getElementById('temp-val').textContent = this.value;"/>
                    <div class="flex justify-between text-xs text-on-surface-variant mt-1">
                        <span>Factual</span>
                        <span>Creativo</span>
                    </div>
                </div>
                <div>
                    <div class="flex justify-between items-end mb-xs">
                        <label class="font-label-md text-label-md text-on-surface" for="max-tokens">Longitud de Respuesta</label>
                        <span class="text-xs text-on-surface-variant">Default: 2048</span>
                    </div>
                    <select class="w-full border-outline-variant rounded-lg bg-surface-container-lowest focus:ring-primary focus:border-primary text-sm p-2" id="max-tokens">
                        <option>Corta (Resumen)</option>
                        <option selected="">Media (Estándar)</option>
                        <option>Larga (Completa)</option>
                    </select>
                </div>
            </div>
        </div>
        <!-- Integrations Card (Full Width) -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-lg shadow-sm md:col-span-2">
            <div class="flex items-center gap-sm mb-md">
                <span class="material-symbols-outlined text-primary" data-icon="api">api</span>
                <h3 class="font-headline-md text-headline-md text-on-surface">Integraciones Institucionales</h3>
            </div>
            <p class="font-body-md text-body-md text-on-surface-variant mb-lg text-sm">Gestiona conexiones API a bases de datos internas para recuperación (RAG).</p>
            <div class="border border-outline-variant rounded-lg divide-y divide-outline-variant">
                <div class="p-md flex items-center justify-between">
                    <div class="flex items-center gap-md">
                        <div class="w-10 h-10 rounded bg-surface-variant flex items-center justify-center text-on-surface-variant">
                            <span class="material-symbols-outlined" data-icon="folder_shared">folder_shared</span>
                        </div>
                        <div>
                            <h4 class="font-label-md text-label-md text-on-surface">Base de Datos de Ciudadanos</h4>
                            <p class="text-xs text-on-surface-variant">PostgreSQL via Internal Gateway</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-sm">
                        <span class="flex items-center gap-1 text-xs font-bold text-on-tertiary-container bg-tertiary-fixed-dim px-2 py-1 rounded-full">
                            <span class="w-2 h-2 rounded-full bg-tertiary"></span> Conectado
                        </span>
                        <button class="p-sm text-secondary hover:text-primary transition-colors"><span class="material-symbols-outlined text-[20px]" data-icon="more_vert">more_vert</span></button>
                    </div>
                </div>
                <div class="p-md flex items-center justify-between">
                    <div class="flex items-center gap-md">
                        <div class="w-10 h-10 rounded bg-surface-variant flex items-center justify-center text-on-surface-variant">
                            <span class="material-symbols-outlined" data-icon="policy">policy</span>
                        </div>
                        <div>
                            <h4 class="font-label-md text-label-md text-on-surface">API de Jurisprudencia</h4>
                            <p class="text-xs text-on-surface-variant">External REST Endpoint</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-sm">
                        <span class="flex items-center gap-1 text-xs font-bold text-on-error-container bg-error-container px-2 py-1 rounded-full">
                            <span class="w-2 h-2 rounded-full bg-error"></span> Error
                        </span>
                        <button class="font-label-sm text-label-sm text-primary hover:underline px-2">Reconectar</button>
                    </div>
                </div>
            </div>
            <button class="mt-md text-primary font-label-md text-label-md hover:underline flex items-center gap-xs">
                <span class="material-symbols-outlined text-[18px]" data-icon="add_link">add_link</span> Añadir Integración
            </button>
        </div>
    </div>
    <div class="mt-xl flex justify-end gap-md border-t border-outline-variant pt-lg">
        <button class="px-lg py-2 border border-primary text-primary font-label-md text-label-md rounded-lg hover:bg-surface-container-low transition-colors min-h-[44px]">Restaurar</button>
        <button class="px-lg py-2 bg-primary text-on-primary font-label-md text-label-md rounded-lg hover:bg-on-primary-fixed-variant transition-colors min-h-[44px]">Guardar Configuración</button>
    </div>
</div>

