@page "/documentos"

<PageTitle>Documentos Analizados - AdminAI</PageTitle>

<div class="content">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Documentos Analizados</h2>
        <button class="gov-btn gov-btn-primary">Sincronizar RSS</button>
    </div>

    <div class="gov-card">
        <ul class="gov-list">
            <li class="gov-list-item d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-1" style="font-family: var(--font-headline); color: var(--primary);">Reglamento de Tránsito Municipal</h5>
                    <p class="mb-0 text-muted" style="font-family: var(--font-body); font-size: 0.9em;">Actualizado hace 2 días • 15 páginas</p>
                </div>
                <span class="gov-chip approved">Indexado</span>
            </li>
            <li class="gov-list-item d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-1" style="font-family: var(--font-headline); color: var(--primary);">Plan de Desarrollo Urbano 2026</h5>
                    <p class="mb-0 text-muted" style="font-family: var(--font-body); font-size: 0.9em;">Actualizado hace 1 semana • 120 páginas</p>
                </div>
                <span class="gov-chip approved">Indexado</span>
            </li>
            <li class="gov-list-item d-flex justify-content-between align-items-center">
                <div>
                    <h5 class="mb-1" style="font-family: var(--font-headline); color: var(--primary);">Nuevas Tarifas de Predial (Borrador)</h5>
                    <p class="mb-0 text-muted" style="font-family: var(--font-body); font-size: 0.9em;">Actualizado hace 1 hora • 5 páginas</p>
                </div>
                <span class="gov-chip pending">Procesando</span>
            </li>
        </ul>
    </div>
</div>

@code {
    
}
