@page "/historial"
<PageTitle>Historial de Consultas - AdminAI</PageTitle>

<div class="flex-1 overflow-y-auto p-margin-mobile md:p-margin-desktop">
    <div class="max-w-[max-width] mx-auto w-full flex flex-col gap-lg">
        <!-- Page Title -->
        <div class="flex flex-col gap-xs border-b border-outline-variant pb-md">
            <h1 class="font-headline-xl-mobile md:font-headline-xl text-headline-xl-mobile md:text-headline-xl text-on-surface">Historial de Consultas</h1>
            <p class="font-body-md text-body-md text-secondary">Revisa análisis anteriores, consultas y documentación legislativa extraída.</p>
        </div>
        <!-- Control Bar: Search & Filter -->
        <div class="bg-surface-container-lowest border border-outline-variant rounded-xl p-sm shadow-sm flex flex-col sm:flex-row gap-sm items-center">
            <!-- Search Input -->
            <div class="flex-1 flex items-center gap-sm bg-surface px-md py-2.5 rounded-lg border border-outline-variant focus-within:border-primary focus-within:ring-2 focus-within:ring-primary/20 transition-all w-full group">
                <span class="material-symbols-outlined text-secondary group-focus-within:text-primary transition-colors">search</span>
                <input class="bg-transparent border-none outline-none w-full text-on-surface font-body-md text-body-md placeholder:text-secondary placeholder:font-body-md p-0 focus:ring-0" placeholder="Buscar por título, asunto o fecha..." type="text"/>
            </div>
            <!-- Filter Button -->
            <button class="flex items-center justify-center gap-sm px-4 py-2.5 border border-outline-variant rounded-lg hover:bg-surface-container-low transition-colors text-on-surface font-label-md text-label-md w-full sm:w-auto whitespace-nowrap bg-surface font-medium">
                <span class="material-symbols-outlined text-[20px]">filter_list</span>
                Filtros
            </button>
        </div>
        <!-- History Feed -->
        <div class="flex flex-col gap-md">
            <!-- Time Group Header -->
            <div class="flex items-center gap-sm mt-sm">
                <div class="font-label-sm text-label-sm text-secondary uppercase tracking-widest font-semibold">Hoy</div>
                <div class="h-px bg-outline-variant flex-1"></div>
            </div>
            <!-- History Card 1 -->
            <a class="group block bg-surface-container-lowest border border-outline-variant rounded-xl p-md md:p-lg hover:shadow-[0_4px_12px_rgba(0,0,0,0.05)] hover:border-outline transition-all duration-200 relative overflow-hidden" href="#">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-transparent group-hover:bg-primary transition-colors"></div>
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-sm mb-md">
                    <div>
                        <h3 class="font-headline-md text-[20px] text-on-surface group-hover:text-primary transition-colors mb-xs">Consulta BOE 12/03</h3>
                        <p class="font-body-md text-body-md text-on-surface-variant line-clamp-2 md:line-clamp-1 max-w-3xl">Análisis detallado de la nueva normativa de contratación pública publicada en el Boletín Oficial del Estado, sección I y II.</p>
                    </div>
                    <div class="flex items-center gap-xs text-secondary font-label-sm text-label-sm whitespace-nowrap shrink-0">
                        <span class="material-symbols-outlined text-[16px]">schedule</span> 10:45 AM
                    </div>
                </div>
                <div class="flex flex-wrap items-center justify-between gap-sm">
                    <div class="flex flex-wrap gap-xs">
                        <span class="bg-secondary-container text-on-secondary-container font-label-sm text-label-sm px-2.5 py-1 rounded-full flex items-center gap-1 border border-outline-variant/30">
                            <span class="material-symbols-outlined text-[14px]">account_balance</span> BOE
                        </span>
                        <span class="bg-surface-variant text-on-surface-variant font-label-sm text-label-sm px-2.5 py-1 rounded-full border border-outline-variant/30">Contratación Pública</span>
                        <span class="bg-surface-variant text-on-surface-variant font-label-sm text-label-sm px-2.5 py-1 rounded-full border border-outline-variant/30">Normativa</span>
                    </div>
                    <div class="text-primary font-label-md text-label-md flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                        Ver Detalles <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                    </div>
                </div>
            </a>
            <!-- History Card 2 -->
            <a class="group block bg-surface-container-lowest border border-outline-variant rounded-xl p-md md:p-lg hover:shadow-[0_4px_12px_rgba(0,0,0,0.05)] hover:border-outline transition-all duration-200 relative overflow-hidden" href="#">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-transparent group-hover:bg-primary transition-colors"></div>
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-sm mb-md">
                    <div>
                        <h3 class="font-headline-md text-[20px] text-on-surface group-hover:text-primary transition-colors mb-xs">Análisis BOPM Vivienda</h3>
                        <p class="font-body-md text-body-md text-on-surface-variant line-clamp-2 md:line-clamp-1 max-w-3xl">Extracción de requisitos para subvenciones de rehabilitación de viviendas energéticamente eficientes.</p>
                    </div>
                    <div class="flex items-center gap-xs text-secondary font-label-sm text-label-sm whitespace-nowrap shrink-0">
                        <span class="material-symbols-outlined text-[16px]">schedule</span> 09:12 AM
                    </div>
                </div>
                <div class="flex flex-wrap items-center justify-between gap-sm">
                    <div class="flex flex-wrap gap-xs">
                        <span class="bg-secondary-container text-on-secondary-container font-label-sm text-label-sm px-2.5 py-1 rounded-full flex items-center gap-1 border border-outline-variant/30">
                            <span class="material-symbols-outlined text-[14px]">location_city</span> BOPM
                        </span>
                        <span class="bg-surface-variant text-on-surface-variant font-label-sm text-label-sm px-2.5 py-1 rounded-full border border-outline-variant/30">Vivienda</span>
                        <span class="bg-surface-variant text-on-surface-variant font-label-sm text-label-sm px-2.5 py-1 rounded-full border border-outline-variant/30">Subvenciones</span>
                    </div>
                    <div class="text-primary font-label-md text-label-md flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                        Ver Detalles <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                    </div>
                </div>
            </a>
            <!-- Time Group Header -->
            <div class="flex items-center gap-sm mt-lg">
                <div class="font-label-sm text-label-sm text-secondary uppercase tracking-widest font-semibold">Ayer</div>
                <div class="h-px bg-outline-variant flex-1"></div>
            </div>
            <!-- History Card 3 -->
            <a class="group block bg-surface-container-lowest border border-outline-variant rounded-xl p-md md:p-lg hover:shadow-[0_4px_12px_rgba(0,0,0,0.05)] hover:border-outline transition-all duration-200 relative overflow-hidden" href="#">
                <div class="absolute left-0 top-0 bottom-0 w-1 bg-transparent group-hover:bg-primary transition-colors"></div>
                <div class="flex flex-col sm:flex-row sm:justify-between sm:items-start gap-sm mb-md">
                    <div>
                        <h3 class="font-headline-md text-[20px] text-on-surface group-hover:text-primary transition-colors mb-xs">Resumen Ley 39/2015</h3>
                        <p class="font-body-md text-body-md text-on-surface-variant line-clamp-2 md:line-clamp-1 max-w-3xl">Puntos clave sobre el Procedimiento Administrativo Común de las Administraciones Públicas aplicables a expedientes digitales.</p>
                    </div>
                    <div class="flex items-center gap-xs text-secondary font-label-sm text-label-sm whitespace-nowrap shrink-0">
                        <span class="material-symbols-outlined text-[16px]">calendar_today</span> 11 Mar
                    </div>
                </div>
                <div class="flex flex-wrap items-center justify-between gap-sm">
                    <div class="flex flex-wrap gap-xs">
                        <span class="bg-secondary-container text-on-secondary-container font-label-sm text-label-sm px-2.5 py-1 rounded-full flex items-center gap-1 border border-outline-variant/30">
                            <span class="material-symbols-outlined text-[14px]">gavel</span> Legislación Estatal
                        </span>
                        <span class="bg-surface-variant text-on-surface-variant font-label-sm text-label-sm px-2.5 py-1 rounded-full border border-outline-variant/30">Administración Electrónica</span>
                    </div>
                    <div class="text-primary font-label-md text-label-md flex items-center gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                        Ver Detalles <span class="material-symbols-outlined text-[18px]">arrow_forward</span>
                    </div>
                </div>
            </a>
        </div>
        <!-- Load More / End of results -->
        <div class="py-lg flex justify-center pb-xl">
            <button class="font-label-md text-label-md text-secondary hover:text-primary transition-colors border border-outline-variant rounded-lg px-6 py-2 hover:bg-surface-container-low bg-surface">
                Cargar más historial
            </button>
        </div>
    </div>
</div>

