@page "/perfil"
@using Microsoft.AspNetCore.Components.Authorization
@using AsistenteAyuntamiento.Shared.Features.Users
@using AsistenteAyuntamiento.Web.Client
@inject UserApiClient UserApi
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Administrador,funcionario")]
@rendermode InteractiveServer
<PageTitle>Perfil de Usuario - AdminAI</PageTitle>

<div class="max-w-[max-width] mx-auto px-margin-mobile md:px-margin-desktop py-xl md:py-margin-desktop grid grid-cols-1 md:grid-cols-12 gap-gutter">
    <!-- Page Header -->
    <div class="col-span-1 md:col-span-12 mb-lg">
        <h2 class="font-headline-lg text-headline-lg-mobile md:text-headline-lg text-on-surface">Perfil de Usuario</h2>
        <p class="text-secondary mt-xs">Gestiona tu identidad y preferencias institucionales.</p>
    </div>
    
    @if (_isLoading)
    {
        <div class="col-span-1 md:col-span-12 flex justify-center py-xl">
            <span class="material-symbols-outlined animate-spin text-[32px] text-primary">progress_activity</span>
        </div>
    }
    else
    {
        <!-- Profile Overview Card (Bento Style) -->
        <div class="col-span-1 md:col-span-4 bg-surface-container-lowest border border-outline-variant rounded-xl p-lg shadow-sm flex flex-col items-center text-center">
            <div class="relative mb-md">
                <img alt="Profile Picture" class="w-32 h-32 rounded-full border-4 border-surface shadow-sm object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCMRN2ws45NQQebC13DPxOmCDRrtBTQvoGxtQTQsFK3J86NHIE6Ckmz0VHKA_UCkATuJlpXU20stNA6vF58UzTJbmlj7aJLHx6HYPl5toEKEH8KtUmI1C-Fnkf2swPSsdLb1c0KFgetIbkAYYyZItv4Fw9YMTyoBGUf2NNwHqBAFMCRKJeaRWTzFxS-11GxA3Ek-HH_h5rQLZRRFFRF-wOhZCNIkzKVePBzxvk4mME7o-SHBiBw3DdT"/>
                <button class="absolute bottom-0 right-0 bg-primary text-on-primary p-sm rounded-full shadow-md hover:bg-on-primary-fixed-variant transition-colors flex items-center justify-center">
                    <span class="material-symbols-outlined text-[18px]">edit</span>
                </button>
            </div>
            <AuthorizeView>
                <Authorized>
                    <h3 class="font-headline-md text-headline-md text-on-surface">@(_profile.FullName ?? context.User.Identity?.Name)</h3>
                    <p class="font-label-md text-label-md text-secondary mt-xs">@(_profile.Position ?? "Sin rol especificado")</p>
                </Authorized>
            </AuthorizeView>
            <div class="mt-md bg-surface-container-low px-md py-xs rounded-full border border-outline-variant inline-flex items-center gap-sm">
                <span class="w-2 h-2 rounded-full bg-tertiary-container"></span>
                <span class="font-label-sm text-label-sm text-on-surface-variant">Activo</span>
            </div>
        </div>
        <!-- Main Settings Canvas -->
        <div class="col-span-1 md:col-span-8 flex flex-col gap-gutter">
            <!-- Institutional Details Form -->
            <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm overflow-hidden">
                <div class="px-lg py-md border-b border-outline-variant bg-surface-container-low">
                    <h4 class="font-body-lg text-body-lg font-semibold text-on-surface">Detalles Institucionales</h4>
                </div>
                <div class="p-lg grid grid-cols-1 md:grid-cols-2 gap-md">
                    <div class="flex flex-col gap-xs">
                        <label class="font-label-md text-label-md text-on-surface-variant" for="fullName">Nombre Completo</label>
                        <input @bind="_profile.FullName" class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm font-body-md text-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary-container transition-all" id="fullName" type="text" />
                    </div>
                    <div class="flex flex-col gap-xs">
                        <label class="font-label-md text-label-md text-on-surface-variant" for="email">Auth0 ID (Solo lectura)</label>
                        <input @bind="_profile.Auth0UserId" class="w-full bg-surface-container-low border border-outline-variant rounded-lg px-md py-sm font-body-md text-body-md text-secondary cursor-not-allowed" id="email" readonly type="text" />
                    </div>
                    <div class="flex flex-col gap-xs">
                        <label class="font-label-md text-label-md text-on-surface-variant" for="department">Departamento</label>
                        <select @bind="_profile.Department" class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm font-body-md text-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary-container transition-all appearance-none" id="department">
                            <option value="">Selecciona departamento...</option>
                            <option value="Política y Estrategia">Política y Estrategia</option>
                            <option value="Finanzas y Operaciones">Finanzas y Operaciones</option>
                            <option value="Legal">Legal</option>
                            <option value="Recursos Humanos">Recursos Humanos</option>
                            <option value="Atención al Ciudadano">Atención al Ciudadano</option>
                        </select>
                    </div>
                    <div class="flex flex-col gap-xs">
                        <label class="font-label-md text-label-md text-on-surface-variant" for="role">Cargo / Posición</label>
                        <input @bind="_profile.Position" class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm font-body-md text-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary-container transition-all" id="role" type="text" />
                    </div>
                    <div class="flex flex-col gap-xs md:col-span-2">
                        <label class="font-label-md text-label-md text-on-surface-variant" for="phone">Teléfono de Contacto</label>
                        <input @bind="_profile.PhoneNumber" class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm font-body-md text-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary-container transition-all" id="phone" type="tel" />
                    </div>
                </div>
                <div class="px-lg py-md border-t border-outline-variant bg-surface flex justify-end items-center gap-md">
                    @if (_isSaving)
                    {
                        <span class="text-secondary font-label-sm">Guardando...</span>
                    }
                    else if (_savedSuccess)
                    {
                        <span class="text-tertiary font-label-sm flex items-center gap-1"><span class="material-symbols-outlined text-[16px]">check_circle</span> Guardado correctamente</span>
                    }
                    <button @onclick="SaveChanges" disabled="@_isSaving" class="bg-primary text-on-primary font-label-md text-label-md px-lg py-sm rounded-lg hover:bg-on-primary-fixed-variant transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed">Guardar Cambios</button>
                </div>
            </div>
            <!-- Security & Preferences (Bento Split) -->
            <div class="grid grid-cols-1 md:grid-cols-2 gap-gutter">
                <!-- Security Settings -->
                <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm p-lg">
                    <div class="flex items-center gap-sm mb-md">
                        <span class="material-symbols-outlined text-primary">security</span>
                        <h4 class="font-body-lg text-body-lg font-semibold text-on-surface">Seguridad Auth0</h4>
                    </div>
                    <div class="flex flex-col gap-md">
                        <p class="text-sm text-secondary">La configuración de contraseña y 2FA se gestiona a través de Auth0. Para modificar estos ajustes, cierra sesión y usa la opción de recuperación de contraseña o contacta al administrador.</p>
                    </div>
                </div>
                <!-- Preferences -->
                <div class="bg-surface-container-lowest border border-outline-variant rounded-xl shadow-sm p-lg">
                    <div class="flex items-center gap-sm mb-md">
                        <span class="material-symbols-outlined text-primary">translate</span>
                        <h4 class="font-body-lg text-body-lg font-semibold text-on-surface">Preferencias</h4>
                    </div>
                    <div class="flex flex-col gap-md">
                        <div class="flex flex-col gap-xs">
                            <label class="font-label-md text-label-md text-on-surface-variant" for="language">Idioma</label>
                            <select class="w-full bg-surface-container-lowest border border-outline-variant rounded-lg px-md py-sm font-body-md text-body-md text-on-surface focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary-container transition-all appearance-none" id="language">
                                <option>Español (ES)</option>
                                <option>English (US)</option>
                            </select>
                        </div>
                        <div class="flex items-center justify-between py-sm mt-sm">
                            <div>
                                <p class="font-body-md text-body-md text-on-surface">Contraste Alto</p>
                                <p class="font-label-sm text-label-sm text-secondary">Mejora la legibilidad del texto AI</p>
                            </div>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input class="sr-only peer" type="checkbox" value=""/>
                                <div class="w-11 h-6 bg-surface-variant peer-focus:outline-none rounded-full peer peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:left-[2px] after:bg-white after:border-outline-variant after:border after:rounded-full after:h-5 after:w-5 after:transition-all peer-checked:bg-primary"></div>
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@code {
    private UserProfileDto _profile = new();
    private bool _isLoading = true;
    private bool _isSaving = false;
    private bool _savedSuccess = false;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var p = await UserApi.GetCurrentUserProfileAsync();
            if (p != null)
            {
                _profile = p;
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error loading profile: {ex.Message}");
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task SaveChanges()
    {
        _isSaving = true;
        _savedSuccess = false;
        StateHasChanged();

        try
        {
            var p = await UserApi.UpdateCurrentUserProfileAsync(_profile);
            if (p != null)
            {
                _profile = p;
                _savedSuccess = true;
                
                // Hide success message after 3 seconds
                _ = Task.Run(async () =>
                {
                    await Task.Delay(3000);
                    _savedSuccess = false;
                    await InvokeAsync(StateHasChanged);
                });
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error saving profile: {ex.Message}");
        }
        finally
        {
            _isSaving = false;
            StateHasChanged();
        }
    }
}
